# .env file

# Backend Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/yemen_malnutrition"
REDIS_URL="redis://localhost:6379/0"
JWT_SECRET_KEY="your-jwt-secret-key-replace-with-a-strong-one"
SECRET_KEY="your-secret-key-replace-with-a-strong-one"
DEBUG=True
ENVIRONMENT=development

# Frontend Configuration (optional, default is http://localhost:8000/api/v1 )
VITE_API_URL="http://localhost:8000/api/v1"

# Grafana Admin Password (for Docker deployment )
GRAFANA_PASSWORD="admin"
